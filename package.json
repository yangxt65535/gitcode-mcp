{
  "name": "@yangxt65535/gitcode-mcp",
  "version": "1.1.0",
  "description": "MCP server for Gitcode platform - Issue and Pull Request operations",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "gitcode-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test:issue": "tsx test/issue-get.ts",
    "test:pr": "tsx test/pull-request-get.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "gitcode", "git", "issue", "pull-request"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
